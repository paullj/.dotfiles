BOLD=$'\033[1m'
RESET=$'\033[0m'
RED=$'\033[31m'
DIM_RED=$'\033[2;31m'
BLUE=$'\033[34m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'

echo_c() {
    if command -v printf >/dev/null 2>&1; then
        printf "%b\n" "$1"
    else
        echo -e "$1" 2>/dev/null || echo "$1"
    fi
}

pr() {
    local existing
    if existing=$(gh pr view --json url -q .url 2>/dev/null); then
        echo_c "${YELLOW}${BOLD}exists:${RESET} $existing"
        echo -n "$existing" | pbcopy
        return 0
    fi
    local title="$(git log -1 --format=%s)"
    vared -p "> " title
    local output
    if output=$(gh pr create --title "$title" --body "" 2>&1); then
        echo_c "${GREEN}${BOLD}success:${RESET} $output"
        echo "$output" | tail -1 | pbcopy
    else
        echo_c "${RED}${BOLD}error:${RESET} $output${RESET}"
        return 1
    fi
}
